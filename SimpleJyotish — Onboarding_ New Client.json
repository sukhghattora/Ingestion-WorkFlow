    {
      "parameters": {
        "jsCode": "// ── Verify Razorpay webhook signature + extract birth details ──\n// SECURITY: confirms this request truly came from Razorpay, not a spoofer.\nconst crypto = require('crypto');\n\nconst secret = $env.RAZORPAY_WEBHOOK_SECRET;\nconst signature = $input.item.json.headers['x-razorpay-signature'];\n\n// n8n gives the raw body as a string when rawBody=true\nconst rawBody = $input.item.json.body;\nconst bodyString = typeof rawBody === 'string' ? rawBody : JSON.stringify(rawBody);\n\nif (secret && signature) {\n  const expected = crypto.createHmac('sha256', secret).update(bodyString).digest('hex');\n  if (expected !== signature) {\n    throw new Error('Invalid Razorpay webhook signature — request rejected.');\n  }\n}\n\n// Parse the verified body\nconst body = typeof rawBody === 'string' ? JSON.parse(rawBody) : rawBody;\nconst eventType = body.event || '';\nconst payment = body?.payload?.payment?.entity || {};\nconst notes = payment.notes || {};\n\n// Birth details are collected as custom fields on the Razorpay Payment Page.\n// They arrive inside payment.notes. Adjust the keys below to match the exact\n// field names you set up on your Razorpay Payment Page.\nreturn [{\n  json: {\n    eventType,\n    paymentId: payment.id || '',\n    amount: payment.amount ? payment.amount / 100 : 0,   // paise -> rupees\n    currency: payment.currency || 'INR',\n    email: payment.email || '',\n    contact: payment.contact || '',\n    // ── Birth details from the form ──\n    fullName: notes.full_name || notes.name || '',\n    dob: notes.dob || notes.date_of_birth || '',\n    tob: notes.tob || notes.time_of_birth || '',\n    pob: notes.pob || notes.place_of_birth || '',\n    whatsapp: (notes.whatsapp || notes.whatsapp_number || payment.contact || '').replace(/\\s+/g, ''),\n    gender: notes.gender || '',\n    tier: notes.tier || 'Core'\n  }\n}];"
      },
      "id": "8f29b479-b425-40a0-ad63-f3d5ed3cee4d",
      "name": "Verify & Extract",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -480,
        80
      ]
    },
    {
